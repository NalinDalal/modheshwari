generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                    @id @default(uuid())
  email                      String
  password                   String
  name                       String
  role                       Role
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  status                     Boolean
  createdEvents              Event[]                   @relation("EventCreatedBy")
  eventApprovalsReviewed     EventApproval[]           @relation("UserEventApprovals")
  eventRegistrations         EventRegistration[]
  headedFamilies             Family[]                  @relation("FamilyHead")
  families                   FamilyMember[]
  MedicalRecord              MedicalRecord[]
  memberInvitesReceived      MemberInvite[]            @relation("InvitedUser")
  memberInvitesReviewed      MemberInvite[]            @relation("InviteReviewedBy")
  notifications              Notification[]
  payments                   Payment[]
  profile                    Profile?
  approvedResourceRequests   ResourceRequest[]         @relation("ApprovedBy")
  requestedResourceRequests  ResourceRequest[]         @relation("RequestedBy")
  resourceRequestApprovals   ResourceRequestApproval[] @relation("UserResourceRequestApprovals")
  statusUpdateApprovals      StatusUpdateApproval[]    @relation("UserStatusUpdateApprovals")
  statusUpdateRequestsMade   StatusUpdateRequest[]     @relation("StatusUpdateRequestedBy")
  statusUpdateRequestsTarget StatusUpdateRequest[]     @relation("TargetUser")
  relationsFrom              UserRelation[]            @relation("FromUser")
  relationsTo                UserRelation[]            @relation("ToUser")

  @@index([role])
  @@index([email])
  @@index([name])
}

model Profile {
  id                      String                    @id @default(uuid())
  userId                  String                    @unique
  phone                   String?
  address                 String?
  profession              String?
  gotra                   String?
  location                String?
  allergies               String?
  medicalNotes            String?
  fcmToken                String?
  notificationPreferences Json?
  locationLat             Float?
  locationLng             Float?
  locationGeo             Unsupported("geography")?
  locationUpdatedAt       DateTime?
  status                  Boolean
  bloodGroup              bloodGroup
  user                    User                      @relation(fields: [userId], references: [id])

  @@index([profession])
  @@index([gotra])
  @@index([bloodGroup])
  @@index([location])
  @@index([status])
}

model MedicalRecord {
  id          String   @id @default(uuid())
  userId      String
  bloodType   String?
  allergies   String?
  conditions  String?
  medications String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Family {
  id           String         @id @default(uuid())
  name         String
  uniqueId     String         @unique
  headId       String?
  createdAt    DateTime       @default(now())
  head         User?          @relation("FamilyHead", fields: [headId], references: [id])
  members      FamilyMember[]
  MemberInvite MemberInvite[]
}

model FamilyMember {
  id       String   @id @default(uuid())
  familyId String
  userId   String
  role     Role
  joinedAt DateTime @default(now())
  family   Family   @relation(fields: [familyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([familyId, userId, role])
}

model UserRelation {
  id         String       @id @default(uuid())
  fromUserId String
  toUserId   String
  type       RelationType
  createdAt  DateTime     @default(now())
  fromUser   User         @relation("FromUser", fields: [fromUserId], references: [id])
  toUser     User         @relation("ToUser", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId, type])
  @@index([toUserId])
}

model Event {
  id            String              @id @default(uuid())
  name          String
  description   String?
  date          DateTime
  venue         String?
  createdById   String
  status        EventStatus         @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  createdBy     User                @relation("EventCreatedBy", fields: [createdById], references: [id])
  approvals     EventApproval[]
  registrations EventRegistration[]
  Notification  Notification[]
  payments      Payment[]
}

model EventApproval {
  id           String         @id @default(uuid())
  eventId      String
  approverId   String
  approverName String
  role         Role
  remarks      String?
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
  status       ApprovalStatus
  approver     User           @relation("UserEventApprovals", fields: [approverId], references: [id])
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, approverId])
}

model EventRegistration {
  id           String   @id @default(uuid())
  eventId      String
  userId       String
  registeredAt DateTime @default(now())
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model Payment {
  id           String         @id @default(uuid())
  eventId      String
  userId       String
  amount       Float
  status       String
  createdAt    DateTime       @default(now())
  Notification Notification[]
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id])
}

model Resource {
  id               String            @id @default(uuid())
  name             String
  type             String
  description      String?
  capacity         Int?
  status           ResourceStatus    @default(AVAILABLE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  resourceRequests ResourceRequest[]

  @@unique([name, type])
}

model ResourceRequest {
  id           String                    @id @default(uuid())
  userId       String
  approverId   String?
  approverName String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  status       ApprovalStatus
  endDate      DateTime?
  resourceId   String
  startDate    DateTime?
  Notification Notification[]
  approver     User?                     @relation("ApprovedBy", fields: [approverId], references: [id])
  resource     Resource                  @relation(fields: [resourceId], references: [id])
  user         User                      @relation("RequestedBy", fields: [userId], references: [id])
  approvals    ResourceRequestApproval[]

  @@index([userId])
  @@index([approverId])
}

model ResourceRequestApproval {
  id           String          @id @default(uuid())
  requestId    String
  approverId   String
  approverName String
  role         Role
  status       ApprovalStatus
  remarks      String?
  reviewedAt   DateTime?
  createdAt    DateTime        @default(now())
  approver     User            @relation("UserResourceRequestApprovals", fields: [approverId], references: [id])
  request      ResourceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, approverId])
}

model Conversation {
  id            String    @id @default(uuid())
  participants  String[]
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      Message[]

  @@index([participants])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  senderName     String
  content        String
  readBy         String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Notification {
  id                    String                 @id @default(uuid())
  userId                String
  message               String
  read                  Boolean                @default(false)
  createdAt             DateTime               @default(now())
  channel               NotificationChannel    @default(IN_APP)
  eventId               String?
  paymentId             String?
  resourceRequestId     String?
  type                  NotificationType
  statusUpdateRequestId String?
  metadata              Json?
  deliveryStrategy      DeliveryStrategy       @default(BROADCAST)
  priority              NotificationPriority   @default(MEDIUM)
  readAt                DateTime?
  fanoutId              String?
  event                 Event?                 @relation(fields: [eventId], references: [id])
  payment               Payment?               @relation(fields: [paymentId], references: [id])
  resourceRequest       ResourceRequest?       @relation(fields: [resourceRequestId], references: [id])
  statusUpdateRequest   StatusUpdateRequest?   @relation("StatusUpdateRequestNotifications", fields: [statusUpdateRequestId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id])
  deliveries            NotificationDelivery[]

  @@index([userId, read])
  @@index([createdAt])
  @@index([deliveryStrategy, read])
}

model NotificationDelivery {
  id             String              @id @default(uuid())
  notificationId String
  channel        NotificationChannel
  status         DeliveryStatus      @default(PENDING)
  attemptCount   Int                 @default(0)
  lastAttemptAt  DateTime?
  deliveredAt    DateTime?
  scheduledFor   DateTime?
  error          String?
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  notification   Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status, scheduledFor])
  @@index([channel, status])
}

model FanoutAudit {
  id             String       @id @default(uuid())
  fanoutId       String       @unique
  initiatedBy    String
  recipientCount Int
  channels       String[]
  message        Json?
  priority       String?
  status         FanoutStatus @default(PENDING)
  error          String?
  createdAt      DateTime     @default(now())
  processedAt    DateTime?
  processedCount Int?

  @@index([fanoutId])
  @@index([status])
}

model MemberInvite {
  id            String       @id @default(uuid())
  familyId      String
  invitedUserId String?
  inviteEmail   String?
  status        InviteStatus @default(PENDING)
  token         String?
  createdAt     DateTime     @default(now())
  expiresAt     DateTime?
  reviewedById  String?
  reviewedAt    DateTime?
  remarks       String?
  family        Family       @relation(fields: [familyId], references: [id])
  invitedUser   User?        @relation("InvitedUser", fields: [invitedUserId], references: [id])
  reviewedBy    User?        @relation("InviteReviewedBy", fields: [reviewedById], references: [id])

  @@unique([familyId, inviteEmail])
  @@index([familyId])
}

model StatusUpdateRequest {
  id            String                 @id @default(uuid())
  targetUserId  String
  requestedById String
  reason        String?
  finalStatus   String?
  status        ApprovalStatus         @default(PENDING)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  reviewedAt    DateTime?
  Notification  Notification[]         @relation("StatusUpdateRequestNotifications")
  approvals     StatusUpdateApproval[]
  requestedBy   User                   @relation("StatusUpdateRequestedBy", fields: [requestedById], references: [id])
  targetUser    User                   @relation("TargetUser", fields: [targetUserId], references: [id])

  @@index([targetUserId])
  @@index([requestedById])
}

model StatusUpdateApproval {
  id           String              @id @default(uuid())
  requestId    String
  approverId   String
  approverName String
  role         Role
  status       ApprovalStatus      @default(PENDING)
  remarks      String?
  reviewedAt   DateTime?
  createdAt    DateTime            @default(now())
  approver     User                @relation("UserStatusUpdateApprovals", fields: [approverId], references: [id])
  request      StatusUpdateRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, approverId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum Role {
  COMMUNITY_HEAD
  COMMUNITY_SUBHEAD
  GOTRA_HEAD
  FAMILY_HEAD
  MEMBER
}

enum bloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

enum RelationType {
  SPOUSE
  PARENT
  CHILD
  SIBLING
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ResourceStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
  UNAVAILABLE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum NotificationChannel {
  EMAIL
  IN_APP
  PUSH
  SMS
}

enum NotificationType {
  EVENT_APPROVAL
  EVENT_REGISTRATION
  RESOURCE_REQUEST
  PAYMENT_RECEIPT
  GENERIC
  STATUS_UPDATE_REQUEST
}

enum DeliveryStrategy {
  BROADCAST
  ESCALATION
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  SENT
  DELIVERED
  FAILED
  CANCELLED
  PROCESSING
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FanoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum InviteStatus {
  PENDING
  APPROVED
  REJECTED
}
